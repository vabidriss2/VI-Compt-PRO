rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          (request.auth.token.email == "vabidriss@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserData().role == 'admin' || getUserData().role == 'super_admin'))
        );
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == 'super_admin';
    }

    function isAccountant() {
      return isAuthenticated() && (getUserData().role == 'comptable' || isAdmin());
    }

    function isConsultant() {
      return isAuthenticated() && (getUserData().role == 'consultant' || isAccountant());
    }

    function belongsToCompany(companyId) {
      return isAuthenticated() && getUserData().companyId == companyId;
    }

    // Validation helpers
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['email', 'role', 'companyId']) &&
             data.email is string && data.email.size() < 100 &&
             data.role in ['super_admin', 'admin', 'comptable', 'consultant', 'none'] &&
             (data.companyId is string || data.companyId == null);
    }

    function isValidAccount(data) {
      return hasRequiredFields(['code', 'name', 'type', 'companyId']) &&
             isValidString(data.code, 1, 20) &&
             isValidString(data.name, 1, 100) &&
             data.type in ['asset', 'liability', 'equity', 'revenue', 'expense'] &&
             data.companyId is string;
    }

    function isValidTransaction(data) {
      return hasRequiredFields(['date', 'description', 'companyId']) &&
             isValidString(data.date, 10, 10) &&
             isValidString(data.description, 1, 500) &&
             data.companyId is string;
    }

    function isValidJournalEntry(data) {
      return hasRequiredFields(['transactionId', 'accountId', 'companyId']) &&
             data.transactionId is string &&
             data.accountId is string &&
             data.debit is number && data.debit >= 0 &&
             data.credit is number && data.credit >= 0 &&
             data.companyId is string;
    }

    function isValidContact(data) {
      return hasRequiredFields(['name', 'type', 'companyId']) &&
             isValidString(data.name, 1, 100) &&
             data.type in ['customer', 'supplier'] &&
             data.companyId is string;
    }

    function isValidInvoice(data) {
      return hasRequiredFields(['contactId', 'type', 'number', 'date', 'totalAmount', 'companyId']) &&
             data.contactId is string &&
             data.type in ['sale', 'purchase'] &&
             isValidString(data.number, 1, 50) &&
             data.totalAmount is number &&
             data.companyId is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || belongsToCompany(getUserData().companyId));
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin()) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && 
        (
          (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL'])) ||
          (isAdmin() && belongsToCompany(resource.data.companyId) && isValidUser(request.resource.data))
        );
    }

    // Companies collection
    match /companies/{companyId} {
      allow read: if isAuthenticated() && belongsToCompany(companyId);
      allow create: if isAuthenticated();
      allow update: if isAdmin() && belongsToCompany(companyId);

      // Invitations
      match /invitations/{invitationId} {
        allow read: if belongsToCompany(companyId);
        allow create: if isAdmin() && belongsToCompany(companyId);
        allow update: if isAdmin() && belongsToCompany(companyId);
        allow delete: if isAdmin() && belongsToCompany(companyId);
      }

      // Sub-collections under company
      match /accounts/{accountId} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAccountant() && belongsToCompany(companyId) && isValidAccount(request.resource.data);
        allow update: if isAccountant() && belongsToCompany(companyId) && isValidAccount(request.resource.data);
        allow delete: if isAdmin() && belongsToCompany(companyId);
      }

      match /transactions/{transactionId} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAccountant() && belongsToCompany(companyId) && isValidTransaction(request.resource.data);
        allow update: if isAccountant() && belongsToCompany(companyId) && isValidTransaction(request.resource.data);
      }

      match /journal_entries/{entryId} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAccountant() && belongsToCompany(companyId) && isValidJournalEntry(request.resource.data);
        allow update: if isAccountant() && belongsToCompany(companyId) && isValidJournalEntry(request.resource.data);
      }

      match /contacts/{contactId} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAccountant() && belongsToCompany(companyId) && isValidContact(request.resource.data);
        allow update: if isAccountant() && belongsToCompany(companyId) && isValidContact(request.resource.data);
      }

      match /invoices/{invoiceId} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAccountant() && belongsToCompany(companyId) && isValidInvoice(request.resource.data);
        allow update: if isAccountant() && belongsToCompany(companyId) && isValidInvoice(request.resource.data);
      }

      match /taxes/{taxId} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAdmin() && belongsToCompany(companyId);
        allow update: if isAdmin() && belongsToCompany(companyId);
      }

      match /banks/{bankId} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAdmin() && belongsToCompany(companyId);
        allow update: if isAdmin() && belongsToCompany(companyId);
        allow delete: if isAdmin() && belongsToCompany(companyId);
      }

      match /vat_declarations/{id} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAccountant() && belongsToCompany(companyId);
      }

      match /periods/{id} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAdmin() && belongsToCompany(companyId);
        allow update: if isAdmin() && belongsToCompany(companyId);
      }

      match /archives/{id} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAdmin() && belongsToCompany(companyId);
      }

      match /revisions/{id} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAccountant() && belongsToCompany(companyId);
      }

      match /bank_statements/{id} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAccountant() && belongsToCompany(companyId);
      }

      match /payment_batches/{id} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAccountant() && belongsToCompany(companyId);
      }

      match /entry_templates/{id} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAccountant() && belongsToCompany(companyId);
        allow update: if isAccountant() && belongsToCompany(companyId);
        allow delete: if isAccountant() && belongsToCompany(companyId);
      }

      match /email_logs/{id} {
        allow read: if isAdmin() && belongsToCompany(companyId);
        allow create: if isAuthenticated() && belongsToCompany(companyId);
      }

      match /analytical_plans/{planId} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAccountant() && belongsToCompany(companyId);
        allow update: if isAccountant() && belongsToCompany(companyId);
        allow delete: if isAccountant() && belongsToCompany(companyId);
      }

      match /journals/{journalId} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAccountant() && belongsToCompany(companyId);
        allow update: if isAccountant() && belongsToCompany(companyId);
        allow delete: if isAccountant() && belongsToCompany(companyId);
      }

      match /audit_logs/{logId} {
        allow read: if isAdmin() && belongsToCompany(companyId);
        allow create: if isAuthenticated() && belongsToCompany(companyId);
      }

      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && belongsToCompany(companyId);
        allow create: if isAuthenticated() && belongsToCompany(companyId);
        allow update: if isAuthenticated() && belongsToCompany(companyId);
      }

      match /products/{productId} {
        allow read: if isConsultant() && belongsToCompany(companyId);
        allow create: if isAdmin() && belongsToCompany(companyId);
        allow update: if isAdmin() && belongsToCompany(companyId);
        allow delete: if isAdmin() && belongsToCompany(companyId);
      }
    }
  }
}
